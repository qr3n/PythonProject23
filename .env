# VPN Subscription Manager Config

# Local DB (our project)
DATABASE_URL=postgresql+asyncpg://vpn:vpnpass@vpn-sub-db:5432/vpndb

# Redis (cache)
REDIS_URL=redis://vpn-sub-redis:6379/0

# Admin Auth
ADMIN_API_KEY=change-me

# Public Base URL
BASE_URL=http://sub.hazeevpn.com

# --- Middleware / Upstream Settings ---
# Where the original subscription config comes from
SUBSCRIPTION_PAGE_URL=http://remnawave-subscription-page:3010

# External Databases (Copied from title_middleware)
REMNAWAVE_DB_URL=postgresql://postgres:758610759ecccd4ff53e72ab1861d78fa5b4e58a34e415d1@remnawave-db:5432/postgres
DB_SCHEMA=public

BOT_DB_URL=postgres://aerokit:aerokit@hazeevpnv4-postgres-1:5432/aerokit
BOT_DB_SCHEMA=public

API_TIMEOUT_SECONDS=3.0

# Pool Settings
OUTBOUNDS_PER_USER=6
PROBE_INTERVAL_SECONDS=30
MIN_HEALTH_SCORE=0.05
